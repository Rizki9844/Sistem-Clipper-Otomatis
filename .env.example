# ==============================================================
# AutoClipperPro - Environment Variables
# ==============================================================
# 🟢 WAJIB SEKARANG  = Harus diisi sebelum deploy
# 🟡 OPSIONAL AWAL   = Diisi kalau mau fitur itu aktif
# 🔴 NANTI SAJA      = Isi setelah ada user / revenue
# ==============================================================
# Copy file ini ke .env lalu isi nilainya.
# JANGAN commit file .env ke git!
# ==============================================================

# ============================================================
# 🟢 WAJIB: APPLICATION CORE
# ============================================================
APP_NAME=AutoClipperPro
APP_ENV=production
DEBUG=false

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GANTI_DENGAN_RANDOM_STRING_64_KARAKTER

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=GANTI_DENGAN_RANDOM_STRING_64_KARAKTER_BERBEDA
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ============================================================
# 🟢 WAJIB: DATABASE (MongoDB Atlas M0 - GRATIS)
# Cara dapat: https://cloud.mongodb.com → Create cluster → M0 Free
# Format: mongodb+srv://USER:PASS@cluster.mongodb.net/DB?retryWrites=true&w=majority
# ============================================================
MONGODB_URL=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/clipper_db?retryWrites=true&w=majority
MONGODB_DB_NAME=clipper_db

# ============================================================
# 🟢 WAJIB: REDIS (Upstash - GRATIS 500K cmd/bln)
# Cara dapat: https://upstash.com → Create Database → Copy "Redis URL"
# Format: rediss://default:PASSWORD@HOST:PORT
# ============================================================
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379
CELERY_BROKER_URL=rediss://default:PASSWORD@HOST.upstash.io:6379
CELERY_RESULT_BACKEND=rediss://default:PASSWORD@HOST.upstash.io:6379

# ============================================================
# 🟢 WAJIB: AZURE BLOB STORAGE (Student $100 credit)
# Cara dapat: portal.azure.com → Storage Account → Access Keys → Connection String
# ============================================================
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=NAMA_KAMU;AccountKey=KEY_KAMU;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_RAW=raw-videos
AZURE_STORAGE_CONTAINER_CLIPS=processed-clips
AZURE_STORAGE_CONTAINER_THUMBNAILS=thumbnails

# ============================================================
# 🟢 WAJIB: GOOGLE GEMINI (GRATIS 1M tokens/hari)
# Cara dapat: https://aistudio.google.com/apikey → Get API Key
# ============================================================
GEMINI_API_KEY=AIzaSy_KUNCI_KAMU_DISINI
GEMINI_MODEL=gemini-2.5-pro-preview-05-06
WHISPER_MODEL=base

# ============================================================
# 🟢 WAJIB: CORS (isi domain Vercel kamu)
# Cek di: vercel.com → project → Settings → Domains
# ============================================================
CORS_ORIGINS=["http://localhost:3000","https://NAMA-KAMU.vercel.app"]

# ============================================================
# 🟢 WAJIB: RATE LIMITING
# ============================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_GENERAL=60/minute
RATE_LIMIT_SUBMIT=10/minute

# ============================================================
# 🟢 WAJIB: FFmpeg & yt-dlp (sudah ada di Docker image)
# ============================================================
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
YTDLP_PATH=yt-dlp
YTDLP_MAX_DOWNLOAD_RATE=50M

# ============================================================
# 🟢 WAJIB: PROCESSING LIMITS
# ============================================================
MAX_VIDEO_SIZE_MB=500
MAX_VIDEO_DURATION_MINUTES=30
MAX_CONCURRENT_JOBS=2
CLIP_MIN_DURATION_SECONDS=15
CLIP_MAX_DURATION_SECONDS=90
DEFAULT_QUALITY_PRESET=balanced
DEFAULT_TARGET_ASPECT=9:16
DEFAULT_FACE_TRACKING=true
DEFAULT_ADD_CAPTIONS=true

# ============================================================
# 🟡 OPSIONAL: TELEGRAM BOT (notifikasi ke kamu waktu ada job selesai)
# Cara dapat: chat @BotFather di Telegram → /newbot
# Chat ID: kirim pesan ke bot, lalu buka https://api.telegram.org/bot<TOKEN>/getUpdates
# ============================================================
TELEGRAM_BOT_TOKEN=1234567890:ABCDefGhIjKlMnOpQrStUvWxYz
TELEGRAM_CHAT_ID=123456789

# ============================================================
# 🟡 OPSIONAL: SENTRY (error monitoring - GitHub Student free)
# Cara dapat: sentry.io → Create Project → DSN
# ============================================================
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================================
# 🟡 OPSIONAL: WHATSAPP (kalau mau notif WA selain Telegram)
# Cara dapat: developers.facebook.com → WhatsApp → Cloud API
# ============================================================
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=

# ============================================================
# 🔴 NANTI: STRIPE (aktifkan setelah ada user yang mau bayar)
# Cara dapat: dashboard.stripe.com → Developers → API Keys
# Buat produk: Products → Add Product → pilih recurring
# Webhook: Developers → Webhooks → Add endpoint → pilih events:
#   checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_failed
# ============================================================
# STRIPE_SECRET_KEY=sk_live_KAMU
# STRIPE_WEBHOOK_SECRET=whsec_KAMU
# STRIPE_PRICE_STARTER=price_xxx
# STRIPE_PRICE_PRO=price_xxx
# STRIPE_PRICE_BUSINESS=price_xxx
# STRIPE_SUCCESS_URL=https://NAMA-KAMU.vercel.app/billing?success=true
# STRIPE_CANCEL_URL=https://NAMA-KAMU.vercel.app/billing?canceled=true

# ============================================================
# 🔴 NANTI: TIKTOK API (perlu apply + review 2-4 minggu)
# Cara dapat: developers.tiktok.com → Create App → Content Posting API
# ============================================================
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI=https://API-KAMU.herokuapp.com/api/v1/publish/callback/tiktok

# ============================================================
# 🔴 NANTI: INSTAGRAM API (butuh Facebook Business Account)
# Cara dapat: developers.facebook.com → Create App → Instagram Basic Display
# ============================================================
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# INSTAGRAM_REDIRECT_URI=https://API-KAMU.herokuapp.com/api/v1/publish/callback/instagram

# ============================================================
# 🔴 NANTI: YOUTUBE API (paling mudah, langsung dari Google Cloud Console)
# Cara dapat: console.cloud.google.com → APIs → YouTube Data API v3 → OAuth 2.0
# ============================================================
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REDIRECT_URI=https://API-KAMU.herokuapp.com/api/v1/publish/callback/youtube

