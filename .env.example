# ==============================================================
# AutoClipperPro - Environment Variables
# ==============================================================
# Copy this to .env and fill in your values.
# ==============================================================

# --- Application ---
APP_NAME=AutoClipperPro
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-in-production

# --- MongoDB (Atlas M0 Free Tier or local Docker) ---
# Local (Docker):
MONGODB_URL=mongodb://clipper_admin:clipper_dev_password@localhost:27017/clipper_db?authSource=admin
# Atlas (Production):
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/clipper_db?retryWrites=true&w=majority
MONGODB_DB_NAME=clipper_db

# --- Redis (Azure Cache for Redis or local Docker) ---
# Local (Docker):
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Azure (Production):
# REDIS_URL=rediss://:YOUR_REDIS_KEY@your-redis.redis.cache.windows.net:6380/0
# CELERY_BROKER_URL=rediss://:YOUR_REDIS_KEY@your-redis.redis.cache.windows.net:6380/0
# CELERY_RESULT_BACKEND=rediss://:YOUR_REDIS_KEY@your-redis.redis.cache.windows.net:6380/1

# --- Azure Blob Storage ---
# Local (Azurite emulator via Docker):
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;
# Azure (Production):
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_RAW=raw-videos
AZURE_STORAGE_CONTAINER_CLIPS=processed-clips
AZURE_STORAGE_CONTAINER_THUMBNAILS=thumbnails

# --- Google Gemini (FREE — 1M tokens/day) ---
# Get API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-pro-preview-05-06
WHISPER_MODEL=base

# --- Sentry (Error Tracking) ---
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# --- WhatsApp (Meta Cloud API) ---
# Get from: https://developers.facebook.com/apps/
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token

# --- Telegram Bot ---
# Create bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:ABCDefGhIjKlMnOpQrStUvWxYz
TELEGRAM_CHAT_ID=your-chat-id

# --- FFmpeg ---
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# --- yt-dlp ---
YTDLP_PATH=yt-dlp
YTDLP_MAX_DOWNLOAD_RATE=50M

# --- Processing Limits ---
MAX_VIDEO_SIZE_MB=500
MAX_VIDEO_DURATION_MINUTES=120
MAX_CONCURRENT_JOBS=3
CLIP_MIN_DURATION_SECONDS=15
CLIP_MAX_DURATION_SECONDS=90

# --- Quality Defaults ---
DEFAULT_QUALITY_PRESET=balanced
DEFAULT_TARGET_ASPECT=9:16
DEFAULT_FACE_TRACKING=true
DEFAULT_ADD_CAPTIONS=true

# --- CORS (comma-separated if multiple) ---
# CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]
