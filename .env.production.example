# ============================================================
# AutoClipperPro — Production Environment Variables
# ============================================================
# Copy this file and fill in ALL values before deploying.
# DO NOT commit the actual .env file with secrets!
# ============================================================

# ---- Application ----
APP_NAME=AutoClipperPro
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ---- API Server ----
# Heroku sets PORT automatically; for other platforms set it manually
# PORT=8000
CORS_ORIGINS=["https://your-app.vercel.app"]

# ---- Database — MongoDB Atlas ----
# Free tier: M0 (512MB)
# Get connection string from: https://cloud.mongodb.com
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=autoclipperpro

# ---- Cache / Message Broker — Upstash Redis (FREE) ----
# Free tier: 500K commands/month, 256MB
# Sign up: https://console.upstash.com (GitHub login)
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
CELERY_BROKER_URL=rediss://default:<password>@<host>.upstash.io:6379/0
CELERY_RESULT_BACKEND=rediss://default:<password>@<host>.upstash.io:6379/1

# ---- Celery optimization (hemat Upstash commands) ----
CELERY_BROKER_TRANSPORT_OPTIONS={"visibility_timeout": 3600, "polling_interval": 5}
CELERY_RESULT_EXPIRES=3600

# ---- Storage — Azure Blob Storage ----
# Azure Student Pack: $100 credit
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_RAW=raw-videos
AZURE_STORAGE_CONTAINER_CLIPS=processed-clips
AZURE_STORAGE_CONTAINER_THUMBNAILS=thumbnails

# ---- AI Services — Google Gemini (FREE) ----
# Get FREE API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM, 1M tokens/day — enough for hundreds of videos!
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-pro-preview-05-06

# Whisper model size (tiny/base/small/medium/large)
# Runs LOCALLY on worker — completely free
# tiny = ~75MB RAM, base = ~200MB RAM
WHISPER_MODEL_SIZE=base

# ---- Notifications ----
# Telegram Bot (@BotFather → /newbot → token)
TELEGRAM_BOT_TOKEN=<bot_token>
TELEGRAM_CHAT_ID=<your_chat_id>

# WhatsApp Cloud API (Meta Developer Console)
WHATSAPP_PHONE_NUMBER_ID=<phone_number_id>
WHATSAPP_ACCESS_TOKEN=<access_token>
WHATSAPP_RECIPIENT=<recipient_phone>

# ---- Monitoring — Sentry ----
# GitHub Student Pack: free Sentry
SENTRY_DSN=https://<key>@sentry.io/<project_id>
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_ENVIRONMENT=production

# ---- Processing Config ----
MAX_VIDEO_DURATION_MINUTES=120
MAX_FILE_SIZE_MB=500
DEFAULT_QUALITY_PRESET=balanced
MAX_CONCURRENT_JOBS=3

# ---- FFmpeg / yt-dlp ----
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
YTDLP_PATH=/usr/local/bin/yt-dlp
