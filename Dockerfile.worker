# ============================================================
# AutoClipperPro Worker — Celery Worker Dockerfile
# ============================================================
# Heavier image: includes Whisper model dependencies + MediaPipe
# Build via GitHub Actions → Heroku Container Registry
# ============================================================

FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# ---- System Dependencies ----
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    curl \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# ---- Install yt-dlp ----
RUN curl -L https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o /usr/local/bin/yt-dlp \
    && chmod a+rx /usr/local/bin/yt-dlp

WORKDIR /app

# ---- Python Dependencies (layered for cache + memory efficiency) ----
COPY backend/requirements.txt .
COPY backend/requirements-worker.txt .

# Layer 1: Build tools + pinned Google ecosystem (prevents resolution loop)
RUN pip install --no-cache-dir "setuptools<70.0.0" wheel

# Layer 2: Base API requirements (Google deps already pinned in requirements.txt)
RUN pip install --no-cache-dir -r requirements.txt

# Layer 3: Heavy ML packages — one at a time to limit peak RAM usage
# PyTorch CPU (required by whisper) — force binary wheel only
RUN pip install --no-cache-dir --only-binary=:all: \
    torch==2.2.1+cpu --extra-index-url https://download.pytorch.org/whl/cpu

# Layer 4: Whisper (skip torch since already installed)
RUN pip install --no-cache-dir openai-whisper==20240930

# Layer 5: Video + MediaPipe (all have prebuilt wheels)
RUN pip install --no-cache-dir --only-binary=:all: \
    opencv-python-headless==4.9.0.80 \
    mediapipe==0.10.11

# Layer 6: Remaining worker deps
RUN pip install --no-cache-dir \
    ffmpeg-python==0.2.0 \
    moviepy==1.0.3 \
    Pillow==10.2.0 \
    yt-dlp==2024.3.10

# ---- Application Code ----
COPY backend/ .

# ---- Health Check (Celery inspect ping) ----
HEALTHCHECK --interval=60s --timeout=15s --start-period=30s --retries=3 \
    CMD celery -A app.workers.celery_app inspect ping --timeout 10 || exit 1

# ---- Default: Run Celery Worker ----
CMD celery -A app.workers.celery_app worker \
    --loglevel=info \
    --concurrency=2 \
    --max-tasks-per-child=50 \
    --without-heartbeat \
    -Q download,transcribe,analyze,edit,render
